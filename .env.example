# Database (PostgreSQL with pgvector extension)
# POSTGRES_PORT controls the host port exposed by docker-compose.dev.yml.
# DATABASE_URL must use the same port number as POSTGRES_PORT.
POSTGRES_PORT=5433
DATABASE_URL="postgresql://reviewsage:reviewsage@localhost:5433/reviewsage"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"

# GitHub OAuth App
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Anthropic Claude (for embeddings and review generation)
ANTHROPIC_API_KEY=""

# Redis (for BullMQ job queues)
# REDIS_PORT controls the host port exposed by docker-compose.dev.yml.
# REDIS_URL must use the same port number as REDIS_PORT.
REDIS_PORT=6380
REDIS_URL="redis://localhost:6380"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="ReviewSage"

# Ollama (optional — local LLM, no API cost)
# In Docker: http://ollama:11434  |  Local: http://localhost:11434
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://localhost:11434
